{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install && cp -r ../html . && cp -r ../css . && cp -r ../js . && cp -r ../images .",
    "startCommand": "node server.js",
    "rootDir": "backend"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}